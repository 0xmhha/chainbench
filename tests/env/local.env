#!/usr/bin/env bash
# tests/env/local.env — 로컬 노드 환경 (기본)
#
# 로컬은 공개된 Hardhat/Anvil 테스트 키를 쓰므로 private key가 비밀이 아니다(여기 직접 기재 OK).
# 서명은 client_cast(클라이언트 서명), 노드제어는 local 백엔드.

CB_NODE_COUNT=4
CB_TARGET_FMT="%s"                  # node(N) → "N" (로컬 정수 인덱스)
CB_VALIDATOR_KEYSTORE_PASSWORD="1"  # 로컬 preset keystore 비번
EPOCH_LENGTH=30                     # 로컬 regression 프로파일 epochLength (genesis와 일치)
CB_SIGN_BACKEND="client_cast"
CB_NODECTRL_BACKEND="local"

# 계정 주소 (1-based). Hardhat/Anvil 기본 계정 — 공개 테스트 키.
CB_ACCT_ADDR=(
  [1]="0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
  [2]="0x70997970C51812dc3A010C7d01b50e0d17dc79C8"
  [3]="0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC"
  [4]="0x90F79bf6EB2c4f870365E785982E1f101E93b906"
  [5]="0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65"
)

# 공개 테스트 private key (비밀 아님 — chainbench 기존 커밋값). client_cast 서명용.
# closednet.env 에는 이 배열이 없다(방식 B: 키는 서버 keystore에만).
CB_ACCT_PK=(
  [1]="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
  [2]="0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d"
  [3]="0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a"
  [4]="0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6"
  [5]="0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a"
)

# Validator 주소 (preset keystore, node1~node4)
CB_VALIDATOR_ADDR=(
  [1]="0xc17d493883eaa3b4cceb0f214b273392d562f9d8"
  [2]="0x2493a84a8f83cb87fdcbe0bb3b2d313f69a58d3c"
