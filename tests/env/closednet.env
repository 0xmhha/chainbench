#!/usr/bin/env bash
# tests/env/closednet.env — 폐쇄망 서버 환경 (메인넷과 동일 구성)
#
# ★ private key 없음 — 결정#1=방식 B: 키는 폐쇄망 서버 keystore에만 존재.
#   서명은 node_keystore 백엔드(personal_unlockAccount + eth_sendTransaction)로 노드측에서 수행.
# ★ IP/URL 없음 — 결정#2: 폐쇄망 노드 IP와 별칭→URL 매핑은 secret 취급.
#   tests/env/secret/closednet.remotes 에만 두고 활성화 시 remotes.json 레지스트리로 주입한다.
#   여기서는 별칭 문자열(stablenet-bpN)만 사용한다.

CB_NODE_COUNT=7
CB_TARGET_FMT="@stablenet-bp%s"     # node(N) → "@stablenet-bpN" (별칭 — URL은 secret remotes로 해석)
CB_VALIDATOR_KEYSTORE_PASSWORD=""   # 폐쇄망 keystore 빈 비번
EPOCH_LENGTH=140                    # 폐쇄망 프로파일 epochLength
CB_SIGN_BACKEND="node_keystore"
CB_NODECTRL_BACKEND="closednet"

# 계정 주소(공개; private key는 서버 keystore에만 존재해 여기 두지 않음).
CB_ACCT_ADDR=(
  [1]="0x1a898f85ecb79e5dc33aa21c6acacfbf021428d6"
  [2]="0x0e75d1db72e86109b13a87d43aef3b15bb41d61c"
  [3]="0xe475c76f74aee5dcd39197898d24cad8ed47f68e"
  [4]="0xb56ba1dd129ed20bf6f9e0a028a56f437f5a8be5"
  [5]="0x973b7e9f8e49ac4731f8367277d3475f6c19cffd"
  [6]="0x02a30c46f41ccf900a126c6f75fcaf8d5afcae44"
  [7]="0x21a1a95e81d624de4ecc3a4eed0245ab58f1c744"
)

# Validator 주소 (node1~node7)
CB_VALIDATOR_ADDR=(
  [1]="0x518b3efa7db538f29615cb9d76f4ac234ebe5893"
  [2]="0xd76975b29bde03f4c644851393d988ccea9d1471"
  [3]="0x0f51a9c1e728cafd808f570773b4dca201e0892d"
  [4]="0x5b3267f014de8044ffd4d45a575bdfe1e6395060"
  [5]="0xd997f9a99fb33a63e07220f42143f3ee0deedfc0"
  [6]="0x7379433952e44ee51d313a4581f0bb79aa6c4ff2"
  [7]="0xb0a24793c36c8c6489b20f213bd735b9b6749447"
)

# 참고: 위 주소는 공개정보(on-chain)라 커밋한다. 조직 정책상 민감하다고 보면
#       CB_ACCT_ADDR/CB_VALIDATOR_ADDR 도 secret store로 내리고 활성화 시 주입하도록 바꾼다.
